# Fragments environment variables
# Copy to .env and fill in values

# Mock mode — set to 1 for demo/development without network access
FRAGMENTS_MOCK=1

# Network binding
BIND_HOST=127.0.0.1
BACKEND_PORT=8000

# Database path (default: data/fragments.db)
# DB_PATH=data/fragments.db

# Scanning
SCAN_INTERVAL=60
SCAN_SUBNET=192.168.1.0/24

# AI / LLM — required for AI features (chat, compliance, reports)
ANTHROPIC_API_KEY=

# Claude model to use
LLM_MODEL=claude-sonnet-4-20250514

# ChromaDB persistence directory
# CHROMA_PERSIST_DIR=data/chroma

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
